# ── Server ────────────────────────────────────────────────────────────────
PORT=8484
# Public base URL used in returned story links (set to your deployed domain)
PUBLIC_BASE_URL=http://localhost:8484

# ── AI narrative layer (optional — deterministic narrator used when unset) ─
# Any OpenAI-compatible API works (OpenAI, DeepSeek, Groq, OpenRouter, ...)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ── Rate limiting ─────────────────────────────────────────────────────────
# Free stories per IP per day
FREE_DAILY=25

# ── x402 payments (A2MCP paid mode) ───────────────────────────────────────
# "free"      -> every call returns HTTP 200 with the result directly
#                (valid free A2MCP; default; over-quota returns 429)
# "challenge" -> EVERY unpaid call returns a spec-correct x402 v2 HTTP 402
#                challenge (PAYMENT-REQUIRED header — what the marketplace
#                validates). Calls carrying X-PAYMENT are verified + settled
#                through the official OKX facilitator when the credentials
#                below are configured.
X402_MODE=free
# Your receiving wallet on X Layer (eip155:196)
X402_PAY_TO=
# Price per story in USD (settled as USDT0, 6 decimals)
X402_PRICE_USD=0.20

# ── OKX Developer Portal credentials (enable real payment settlement) ─────
# Create at https://web3.okx.com/onchainos/dev-portal → project → API key.
# With these set and X402_MODE=challenge, X-PAYMENT payloads are verified and
# settled via the OKX facilitator (HMAC-signed /api/v6/pay/x402/verify+settle,
# syncSettle: a 200 from Plotline means the payment confirmed on-chain).
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── Storage ───────────────────────────────────────────────────────────────
# Directory where rendered stories are persisted
DATA_DIR=./data
